{
  "manifest_version": 3,
  "name": "Overflow",
  "short_name": "Overflow",
  "version": "1.0.0.0",
  "description": "Free bulk prompt automation for Google Flow. Queue prompts, generate in bulk, download the results.",
  "permissions": ["storage", "downloads", "sidePanel", "scripting", "activeTab", "debugger"],
  "host_permissions": ["https://labs.google/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Overflow"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["https://labs.google/fx/*"],
      "js": ["content-scripts/flow.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://labs.google/fx/*"],
      "js": ["content-scripts/flow-main-world.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
